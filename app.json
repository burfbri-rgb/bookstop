{
  "expo": {
    "name": "Bookstop",
    "slug": "bookstop",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bookstop",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bookstop.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to capture item photos and scan barcodes for inventory management."
      }
    },
    "android": {
      "package": "com.bookstop.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Bookstop to access your camera for item photos and barcode scanning."
        }
      ],
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": ["arm64-v8a", "armeabi-v7a"],
            "enableBundleCompression": true,
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4a37789c-0ff2-41e5-a950-490c419eaa0e"
      }
    },
    "owner": "burf"
  }
}
